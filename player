<?php

// Thumbnail default jika parameter kosong
$default_image = "VCWQViyFh";

// Ambil kode gambar dari URL
$image_code = isset($_GET['img']) ? preg_replace('/[^a-zA-Z0-9]/', '', $_GET['img']) : $default_image;

// Generate URL thumbnail
$thumbnail = "https://cdn.aceimg.com/" . $image_code . ".jpg";

// Link tujuan saat diklik
$target_url = "";

?>
<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Video Player</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html,body{
    width:100%;
    height:100%;
    overflow:hidden;
    background:#fff;
}

.player-link{
    display:block;
    width:100%;
    height:100%;
}

.video-frame{
    position:relative;
    width:100%;
    height:100%;
    display:flex;
    justify-content:center;
    align-items:center;
}

.video-frame img{
    width:100%;
    height:100%;
    object-fit:contain;
}

.video-frame::after{
    content:"";
    position:absolute;
    left:0;
    right:0;
    bottom:0;
    height:30%;
    background:linear-gradient(
        to top,
        rgba(0,0,0,.8),
        transparent
    );
}

.play-button{
    position:absolute;
    width:80px;
    height:80px;
    border-radius:50%;
    background:rgba(0,0,0,.45);
    border:2px solid rgba(255,255,255,.9);
    display:flex;
    align-items:center;
    justify-content:center;
    z-index:2;
    transition:.2s;
}

.play-button:before{
    content:"▶";
    color:#fff;
    font-size:28px;
    margin-left:4px;
}

.video-frame:hover .play-button{
    transform:scale(1.08);
    background:rgba(0,0,0,.6);
}

.controls{
    position:absolute;
    bottom:15px;
    width:90%;
    z-index:2;
}

.progress{
    width:100%;
    height:4px;
    background:rgba(255,255,255,.3);
    border-radius:20px;
    overflow:hidden;
}

.progress-bar{
    width:25%;
    height:100%;
    background:#fff;
}

@media(max-width:768px){

    .play-button{
        width:70px;
        height:70px;
    }

    .play-button:before{
        font-size:24px;
    }

}
</style>
</head>

<body>

<a class="player-link" href="<?= htmlspecialchars($target_url) ?>">

    <div class="video-frame">

        <img
            src="<?= htmlspecialchars($thumbnail) ?>"
            alt="Thumbnail"
            loading="eager"
        >

        <div class="play-button"></div>

        <div class="controls">
            <div class="progress">
                <div class="progress-bar"></div>
            </div>
        </div>

    </div>

</a>

</body>
</html>
